# Secrets for docker compose (DO NOT COMMIT real values)
#
# Copy this file to `.cont_one_app.secrets.env` and fill real secrets locally.
# The `.cont_one_app.secrets.env` file is ignored by git via `.gitignore`.
#
# Grafana MCP (Grafana service account token / API key)
MCP_GRAFANA_API_KEY=REPLACE_ME

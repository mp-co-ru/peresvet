# Defaults for ./run_one_app.sh
# CLI options override these values.

# Registry mirror URL with scheme (http:// or https://). Empty = Docker Hub.
# Public mirror for clients:
PRS_REGISTRY_MIRROR=https://mpcperesvet.matchpoint-consulting.ru/dist/images

# Server name for nginx (empty = current host name).
PRS_HOSTNAME=

# Use HTTPS nginx compose file: true or false.
PRS_SSL=false

# Rebuild application images before start: true or false.
PRS_BUILD=false

# Skip pre-flight pull of required base images: 1 or 0.
PRS_SKIP_IMAGE_PULL=0
